// Factory Method — создание препаратов разных типов без привязки к конкретным классам

подключить "../общее/ошибки_аптеки.сос";
подключить "../общее/разбор_строки.сос";
подключить "../модель/рецептурный_препарат.сос";
подключить "../модель/безрецептурный_препарат.сос";

класс ФабрикаПрепаратов() {
    публичный функция создать(строка тип, целое ид, строка название, вещественное цена, целое количество, строка срок_годности) Препарат {
        если (тип == "рецептурный") {
            вернуть новый РецептурныйПрепарат(ид, название, цена, количество, срок_годности);
        }
        вернуть новый БезрецептурныйПрепарат(ид, название, цена, количество, срок_годности);
    }

    публичный функция из_строки(строка строка_данных) Препарат {
        РазборСтроки разбор = новый РазборСтроки();
        строка[] поля = разбор.разделить(строка_данных, ';');
        если (длина(поля) < 6) {
            бросить новый ошибка_формата_данных("неверный формат записи препарата");
        }
        целое ид = целое(разбор.обрезать(поля[0]));
        строка название = разбор.обрезать(поля[1]);
        вещественное цена = вещественное(разбор.обрезать(поля[2]));
        целое количество = целое(разбор.обрезать(поля[3]));
        строка срок = разбор.обрезать(поля[4]);
        строка тип = разбор.обрезать(поля[5]);
        если (тип == "Р") {
            вернуть новый РецептурныйПрепарат(ид, название, цена, количество, срок);
        }
        вернуть новый БезрецептурныйПрепарат(ид, название, цена, количество, срок);
    }
}
