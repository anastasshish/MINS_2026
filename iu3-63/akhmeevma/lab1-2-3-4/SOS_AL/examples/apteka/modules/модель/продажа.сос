// Запись журнала продаж

класс Продажа() {
    публичный целое ид;
    публичный целое ид_препарата;
    публичный строка название_препарата;
    публичный целое количество;
    публичный вещественное сумма;
    публичный строка дата;
    публичный строка номер_рецепта;

    конструктор(целое ид, целое ид_препарата, строка название_препарата, целое количество, вещественное сумма, строка дата, строка номер_рецепта) {
        этот.ид = ид;
        этот.ид_препарата = ид_препарата;
        этот.название_препарата = название_препарата;
        этот.количество = количество;
        этот.сумма = сумма;
        этот.дата = дата;
        этот.номер_рецепта = номер_рецепта;
    }

    публичный функция описание() строка {
        строка рецепт = этот.номер_рецепта;
        если (длина(рецепт) == 0) {
            рецепт = "без рецепта";
        }
        строка название = этот.название_препарата;
        если (длина(название) == 0) {
            название = "№" + строка(этот.ид_препарата);
        }
        вернуть "Продажа #" + строка(этот.ид) + ": " + название
            + " (ид " + строка(этот.ид_препарата) + ")"
            + ", кол-во " + строка(этот.количество) + ", сумма " + строка(этот.сумма)
            + " руб., дата " + этот.дата + ", " + рецепт;
    }

    публичный функция в_строку() строка {
        вернуть строка(этот.ид) + ";" + строка(этот.ид_препарата) + ";"
            + строка(этот.количество) + ";" + строка(этот.сумма) + ";"
            + этот.дата + ";" + этот.номер_рецепта + ";" + этот.название_препарата;
    }
}
