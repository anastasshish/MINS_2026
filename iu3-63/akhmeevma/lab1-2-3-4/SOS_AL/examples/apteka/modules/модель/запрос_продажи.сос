// Контекст запроса на продажу (для цепочки валидации)

подключить "препарат.сос";

класс ЗапросПродажи() {
    публичный целое ид_препарата;
    публичный целое количество;
    публичный строка номер_рецепта;
    публичный строка дата_продажи;
    публичный Препарат препарат;

    конструктор(целое ид_препарата, целое количество, строка номер_рецепта) {
        этот.ид_препарата = ид_препарата;
        этот.количество = количество;
        этот.номер_рецепта = номер_рецепта;
    }
}
