// Базовый класс лекарственного препарата

класс Препарат() {
    публичный целое ид;
    публичный строка название;
    публичный вещественное цена;
    публичный целое количество;
    публичный строка срок_годности;

    конструктор(целое ид, строка название, вещественное цена, целое количество, строка срок_годности) {
        этот.ид = ид;
        этот.название = название;
        этот.цена = цена;
        этот.количество = количество;
        этот.срок_годности = срок_годности;
    }

    публичный функция рецептурный() логическое {
        вернуть нет;
    }

    публичный функция тип_товара() строка {
        вернуть "безрецептурный";
    }

    публичный функция истекает_до(строка дата) логическое {
        вернуть этот.срок_годности <= дата;
    }

    публичный функция просрочен_на(строка дата) логическое {
        вернуть этот.срок_годности < дата;
    }

    публичный функция описание() строка {
        вернуть "[" + строка(этот.ид) + "] " + этот.название
            + " | " + строка(этот.цена) + " руб."
            + " | остаток: " + строка(этот.количество)
            + " | до " + этот.срок_годности
            + " | " + этот.тип_товара();
    }

    публичный функция в_строку() строка {
        вернуть строка(этот.ид) + ";" + этот.название + ";"
            + строка(этот.цена) + ";" + строка(этот.количество) + ";"
            + этот.срок_годности + ";Б";
    }
}
