// Рецептурный препарат

подключить "препарат.сос";

класс РецептурныйПрепарат(Препарат) {
    конструктор(целое ид, строка название, вещественное цена, целое количество, строка срок_годности) {
        родитель.конструктор(ид, название, цена, количество, срок_годности);
    }

    переопределить публичный функция рецептурный() логическое {
        вернуть да;
    }

    переопределить публичный функция тип_товара() строка {
        вернуть "рецептурный";
    }

    переопределить публичный функция в_строку() строка {
        вернуть строка(этот.ид) + ";" + этот.название + ";"
            + строка(этот.цена) + ";" + строка(этот.количество) + ";"
            + этот.срок_годности + ";Р";
    }
}
