// Интерактивное консольное меню

подключить "../общее/ошибки_аптеки.сос";
подключить "../общее/разбор_строки.сос";
подключить "../сервис/сервис_аптеки.сос";

класс КонсольАптеки() {
    публичный СервисАптеки сервис;
    приватный РазборСтроки разбор;

    конструктор(СервисАптеки сервис) {
        этот.сервис = сервис;
        этот.разбор = новый РазборСтроки();
    }

    приватный функция прочитать(строка подсказка) строка {
        вернуть этот.разбор.обрезать(ввод(подсказка));
    }

    приватный функция пауза() {
        этот.прочитать("Нажмите Enter для продолжения...");
    }

    приватный функция печать_списка(Препарат[] список, строка заголовок) {
        печать("");
        печать("--- " + заголовок + " ---");
        если (длина(список) == 0) {
            печать("(пусто)");
        } иначе {
            целое сч = 0;
            пока (сч < длина(список)) выполнять {
                печать(список[сч].описание());
                сч += 1;
            }
        }
    }

    приватный функция печать_продаж(Продажа[] список, строка заголовок) {
        печать("");
        печать("--- " + заголовок + " ---");
        если (длина(список) == 0) {
            печать("(пусто)");
        } иначе {
            целое сч = 0;
            пока (сч < длина(список)) выполнять {
                печать(список[сч].описание());
                сч += 1;
            }
        }
    }

    приватный функция показать_меню() {
        печать("");
        печать("╔══════════════════════════════════════╗");
        печать("║     ИНФОРМАЦИОННАЯ СИСТЕМА АПТЕКИ    ║");
        печать("╠══════════════════════════════════════╣");
        печать("║  1. Каталог препаратов               ║");
        печать("║  2. Поиск по названию                ║");
        печать("║  3. Истекающие сроки годности        ║");
        печать("║  4. Сортировка по сроку годности     ║");
        печать("║  5. Рецептурные препараты            ║");
        печать("║  6. Безрецептурные препараты         ║");
        печать("║  7. Добавить препарат                ║");
        печать("║  8. Оформить продажу                 ║");
        печать("║  9. Журнал продаж                    ║");
        печать("║ 10. Списать препарат                 ║");
        печать("║ 11. Сбросить тестовые данные         ║");
        печать("║  0. Выход                            ║");
        печать("╚══════════════════════════════════════╝");
    }

    приватный функция действие_каталог() {
        этот.печать_списка(этот.сервис.список_препаратов(), "Каталог препаратов");
        этот.пауза();
    }

    приватный функция действие_поиск() {
        строка запрос = этот.прочитать("Введите часть названия: ");
        если (длина(запрос) == 0) {
            печать("Запрос не может быть пустым.");
        } иначе {
            этот.печать_списка(этот.сервис.найти_по_названию(запрос), "Результаты поиска");
        }
        этот.пауза();
    }

    приватный функция действие_истекающие() {
        строка дата = этот.прочитать("Показать препараты с истекающим сроком до (ГГГГ-ММ-ДД): ");
        если (длина(дата) == 0) {
            печать("Дата не указана.");
        } иначе {
            этот.печать_списка(этот.сервис.найти_истекающие(дата), "Истекающие препараты");
        }
        этот.пауза();
    }

    приватный функция действие_сортировка() {
        этот.печать_списка(этот.сервис.отсортировать_по_сроку(), "Сортировка по сроку годности");
        этот.пауза();
    }

    приватный функция действие_рецептурные() {
        этот.печать_списка(этот.сервис.фильтр_по_рецептурности(да), "Рецептурные препараты");
        этот.пауза();
    }

    приватный функция действие_безрецептурные() {
        этот.печать_списка(этот.сервис.фильтр_по_рецептурности(нет), "Безрецептурные препараты");
        этот.пауза();
    }

    приватный функция действие_добавить() {
        печать("");
        печать("--- Добавление препарата ---");
        целое след_ид = этот.сервис.следующий_ид_препарата();
        печать("Рекомендуемый ид:", строка(след_ид));

        попробовать {
            целое ид = целое(этот.прочитать("Ид: "));
            строка название = этот.прочитать("Название: ");
            если (длина(название) == 0) {
                бросить новый ошибка_формата("название не может быть пустым");
            }
            вещественное цена = вещественное(этот.прочитать("Цена (руб.): "));
            целое количество = целое(этот.прочитать("Количество на складе: "));
            строка срок = этот.прочитать("Срок годности (ГГГГ-ММ-ДД): ");
            печать("Тип: 1 — безрецептурный, 2 — рецептурный");
            строка выбор_типа = этот.прочитать("Тип: ");
            строка тип = "безрецептурный";
            если (выбор_типа == "2") {
                тип = "рецептурный";
            }
            этот.сервис.добавить_препарат(тип, ид, название, цена, количество, срок);
            печать("Препарат успешно добавлен.");
        } словить ошибка_аптеки как е {
            печать("Ошибка:", е.сообщение);
        } словить {
            печать("Ошибка: неверный формат числа или данных.");
        }
        этот.пауза();
    }

    приватный функция действие_продажа() {
        печать("");
        печать("--- Оформление продажи ---");
        печать("Продать можно только непросроченные препараты.");
        этот.печать_списка(этот.сервис.список_препаратов(), "Доступные препараты");

        попробовать {
            целое ид = целое(этот.прочитать("Ид препарата: "));
            Препарат п = этот.сервис.получить_препарат(ид);
            печать("Выбран:", п.описание());
            целое количество = целое(этот.прочитать("Количество: "));
            строка дата = этот.прочитать("Дата продажи (ГГГГ-ММ-ДД): ");
            строка рецепт = "";
            если (п.рецептурный()) {
                рецепт = этот.прочитать("Номер рецепта: ");
            }
            Продажа продажа = этот.сервис.продать(ид, количество, дата, рецепт);
            печать("Продажа оформлена:", продажа.описание());
        } словить ошибка_аптеки как е {
            печать("Ошибка:", е.сообщение);
        } словить {
            печать("Ошибка: неверный формат числа или данных.");
        }
        этот.пауза();
    }

    приватный функция действие_журнал() {
        этот.печать_продаж(этот.сервис.журнал_продаж(), "Журнал продаж");
        этот.пауза();
    }

    приватный функция действие_сброс() {
        печать("");
        печать("--- Сброс тестовых данных ---");
        печать("Файлы препаратов и продаж будут перезаписаны значениями по умолчанию.");
        строка подтверждение = этот.прочитать("Введите «да» для подтверждения: ");
        если (подтверждение == "да") {
            этот.сервис.сбросить_тестовые_данные();
            печать("Тестовые данные восстановлены.");
        } иначе {
            печать("Сброс отменён.");
        }
        этот.пауза();
    }

    приватный функция действие_списать() {
        печать("");
        печать("--- Списание препарата ---");
        печать("Препарат будет удалён со склада без записи в журнал продаж.");
        этот.печать_списка(этот.сервис.список_препаратов(), "Препараты на складе");

        попробовать {
            целое ид = целое(этот.прочитать("Ид препарата для списания: "));
            Препарат п = этот.сервис.получить_препарат(ид);
            печать("Будет списан:", п.описание());
            этот.сервис.списать_препарат(ид);
            печать("Препарат успешно списан.");
        } словить ошибка_аптеки как е {
            печать("Ошибка:", е.сообщение);
        } словить {
            печать("Ошибка: неверный формат числа или данных.");
        }
        этот.пауза();
    }

    публичный функция запустить() {
        логическое работает = да;
        пока (работает) выполнять {
            этот.показать_меню();
            строка выбор = этот.прочитать("Выберите пункт меню: ");

            если (выбор == "1") {
                этот.действие_каталог();
            } иначе_если (выбор == "2") {
                этот.действие_поиск();
            } иначе_если (выбор == "3") {
                этот.действие_истекающие();
            } иначе_если (выбор == "4") {
                этот.действие_сортировка();
            } иначе_если (выбор == "5") {
                этот.действие_рецептурные();
            } иначе_если (выбор == "6") {
                этот.действие_безрецептурные();
            } иначе_если (выбор == "7") {
                этот.действие_добавить();
            } иначе_если (выбор == "8") {
                этот.действие_продажа();
            } иначе_если (выбор == "9") {
                этот.действие_журнал();
            } иначе_если (выбор == "10") {
                этот.действие_списать();
            } иначе_если (выбор == "11") {
                этот.действие_сброс();
            } иначе_если (выбор == "0") {
                печать("Данные сохранены. До свидания!");
                работает = нет;
            } иначе {
                печать("Неизвестный пункт меню. Введите число от 0 до 11.");
            }
        }
    }
}
