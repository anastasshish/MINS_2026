// Unit of Work — атомарное списание и запись продажи

подключить "../общее/ошибки_аптеки.сос";
подключить "../репозиторий/репозиторий_препаратов.сос";
подключить "../репозиторий/репозиторий_продаж.сос";
подключить "../модель/продажа.сос";

класс ЕдиницаРаботы() {
    публичный РепозиторийПрепаратов репозиторий_препаратов;
    публичный РепозиторийПродаж репозиторий_продаж;
    приватный целое[] резерв_количеств;
    приватный целое[] резерв_идов;

    конструктор(РепозиторийПрепаратов репозиторий_препаратов, РепозиторийПродаж репозиторий_продаж) {
        этот.репозиторий_препаратов = репозиторий_препаратов;
        этот.репозиторий_продаж = репозиторий_продаж;
        этот.резерв_количеств = новый целое[0];
        этот.резерв_идов = новый целое[0];
    }

    приватный функция сохранить_снимок(Препарат препарат) {
        добавить(этот.резерв_идов, препарат.ид);
        добавить(этот.резерв_количеств, препарат.количество);
    }

    приватный функция откатить() {
        целое сч = 0;
        пока (сч < длина(этот.резерв_идов)) выполнять {
            Препарат п = этот.репозиторий_препаратов.найти_по_ид(этот.резерв_идов[сч]);
            п.количество = этот.резерв_количеств[сч];
            сч += 1;
        }
        этот.резерв_идов = новый целое[0];
        этот.резерв_количеств = новый целое[0];
    }

    публичный функция выполнить_продажу(Препарат препарат, целое количество, строка дата, строка номер_рецепта) Продажа {
        этот.сохранить_снимок(препарат);
        попробовать {
            препарат.количество = препарат.количество - количество;
            вещественное сумма = препарат.цена * количество;
            целое ид_продажи = этот.репозиторий_продаж.следующий_ид();
            Продажа продажа = новый Продажа(
                ид_продажи, препарат.ид, препарат.название, количество, сумма, дата, номер_рецепта);
            этот.репозиторий_продаж.добавить(продажа);
            этот.репозиторий_препаратов.сохранить();
            этот.репозиторий_продаж.сохранить();
            если (препарат.количество == 0) {
                этот.репозиторий_препаратов.удалить_по_ид(препарат.ид);
                этот.репозиторий_препаратов.сохранить();
            }
            этот.резерв_идов = новый целое[0];
            этот.резерв_количеств = новый целое[0];
            вернуть продажа;
        } словить {
            этот.откатить();
            бросить новый ошибка_транзакции("транзакция продажи отменена");
        } наконец {
            печать("абоба")
        }
    }
}
