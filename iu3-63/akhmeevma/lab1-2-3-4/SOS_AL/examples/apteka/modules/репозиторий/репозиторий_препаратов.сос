// Репозиторий препаратов — хранение в текстовом файле

подключить "../интерфейсы/интерфейс_репозиторий.сос";
подключить "../общее/ошибки_аптеки.сос";
подключить "../общее/разбор_строки.сос";
подключить "../фабрика/фабрика_препаратов.сос";

класс РепозиторийПрепаратов() реализует ИнтерфейсРепозиторий {
    публичный строка путь;
    публичный Препарат[] препараты;
    приватный ФабрикаПрепаратов фабрика;

    конструктор(строка путь) {
        этот.путь = путь;
        этот.препараты = новый Препарат[0];
        этот.фабрика = новый ФабрикаПрепаратов();
    }

    публичный функция загрузить() {
        попробовать {
            строка текст = прочитать_файл(этот.путь);
            РазборСтроки разбор = новый РазборСтроки();
            строка[] строки = разбор.строки_из_текста(текст);
            этот.препараты = новый Препарат[0];
            для строка_данных в строки делать {
                строка_данных = разбор.обрезать(строка_данных);
                если (разбор.не_пустая(строка_данных)) {
                    Препарат п = этот.фабрика.из_строки(строка_данных);
                    если (п.количество > 0) {
                        добавить(этот.препараты, п);
                    }
                }
            }
        } словить ошибка_имени как е {
            этот.препараты = новый Препарат[0];
        }
    }

    публичный функция сохранить() {
        строка текст = "";
        целое сч = 0;
        пока (сч < длина(этот.препараты)) выполнять {
            текст = текст + этот.препараты[сч].в_строку() + "\n";
            сч += 1;
        }
        записать_файл(этот.путь, текст);
    }

    публичный функция найти_по_ид(целое ид) Препарат {
        целое сч = 0;
        пока (сч < длина(этот.препараты)) выполнять {
            если (этот.препараты[сч].ид == ид) {
                вернуть этот.препараты[сч];
            }
            сч += 1;
        }
        бросить новый ошибка_не_найдено("препарат с ид " + строка(ид) + " не найден");
    }

    публичный функция существует_ид(целое ид) логическое {
        целое сч = 0;
        пока (сч < длина(этот.препараты)) выполнять {
            если (этот.препараты[сч].ид == ид) {
                вернуть да;
            }
            сч += 1;
        }
        вернуть нет;
    }

    публичный функция добавить(Препарат препарат) {
        если (этот.существует_ид(препарат.ид)) {
            бросить новый ошибка_формата("препарат с ид " + строка(препарат.ид) + " уже существует");
        }
        добавить(этот.препараты, препарат);
    }

    публичный функция удалить_по_ид(целое ид) {
        Препарат[] осталось = новый Препарат[0];
        целое сч = 0;
        пока (сч < длина(этот.препараты)) выполнять {
            если (этот.препараты[сч].ид != ид) {
                добавить(осталось, этот.препараты[сч]);
            }
            сч += 1;
        }
        этот.препараты = осталось;
    }

    публичный функция все() Препарат[] {
        вернуть этот.препараты;
    }

    публичный функция следующий_ид() целое {
        если (длина(этот.препараты) == 0) {
            вернуть 1;
        }
        целое макс = 0;
        целое сч = 0;
        пока (сч < длина(этот.препараты)) выполнять {
            если (этот.препараты[сч].ид > макс) {
                макс = этот.препараты[сч].ид;
            }
            сч += 1;
        }
        вернуть макс + 1;
    }
}
