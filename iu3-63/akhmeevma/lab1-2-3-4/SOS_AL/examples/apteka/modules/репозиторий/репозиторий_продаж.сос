// Репозиторий журнала продаж

подключить "../интерфейсы/интерфейс_репозиторий.сос";
подключить "../общее/ошибки_аптеки.сос";
подключить "../общее/разбор_строки.сос";
подключить "../модель/продажа.сос";

класс РепозиторийПродаж() реализует ИнтерфейсРепозиторий {
    публичный строка путь;
    публичный Продажа[] продажи;

    конструктор(строка путь) {
        этот.путь = путь;
        этот.продажи = новый Продажа[0];
    }

    публичный функция загрузить() {
        попробовать {
            строка текст = прочитать_файл(этот.путь);
            РазборСтроки разбор = новый РазборСтроки();
            строка[] строки = разбор.строки_из_текста(текст);
            этот.продажи = новый Продажа[0];
            для строка_данных в строки делать {
                строка_данных = разбор.обрезать(строка_данных);
                если (разбор.не_пустая(строка_данных)) {
                    строка[] поля = разбор.разделить(строка_данных, ';');
                    если (длина(поля) < 6) {
                        бросить новый ошибка_формата_данных("неверный формат записи продажи");
                    }
                    строка название = "";
                    если (длина(поля) >= 7) {
                        название = разбор.обрезать(поля[6]);
                    }
                    Продажа п = новый Продажа(
                        целое(разбор.обрезать(поля[0])),
                        целое(разбор.обрезать(поля[1])),
                        название,
                        целое(разбор.обрезать(поля[2])),
                        вещественное(разбор.обрезать(поля[3])),
                        разбор.обрезать(поля[4]), разбор.обрезать(поля[5])
                    );
                    добавить(этот.продажи, п);
                }
            }
        } словить ошибка_имени как е {
            этот.продажи = новый Продажа[0];
        }
    }

    публичный функция сохранить() {
        строка текст = "";
        целое сч = 0;
        пока (сч < длина(этот.продажи)) выполнять {
            текст = текст + этот.продажи[сч].в_строку() + "\n";
            сч += 1;
        }
        записать_файл(этот.путь, текст);
    }

    публичный функция добавить(Продажа продажа) {
        добавить(этот.продажи, продажа);
    }

    публичный функция все() Продажа[] {
        вернуть этот.продажи;
    }

    публичный функция следующий_ид() целое {
        если (длина(этот.продажи) == 0) {
            вернуть 1;
        }
        целое макс = 0;
        целое сч = 0;
        пока (сч < длина(этот.продажи)) выполнять {
            если (этот.продажи[сч].ид > макс) {
                макс = этот.продажи[сч].ид;
            }
            сч += 1;
        }
        вернуть макс + 1;
    }
}
