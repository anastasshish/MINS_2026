// Chain — запрет продажи просроченных препаратов

подключить "обработчик_валидации.сос";
подключить "../общее/ошибки_аптеки.сос";

класс ПроверкаСрока(ОбработчикВалидации) {
    переопределить публичный функция обработать(ЗапросПродажи запрос) {
        если (запрос.препарат.просрочен_на(запрос.дата_продажи)) {
            бросить новый ошибка_срока_годности(
                "препарат просрочен: срок годности " + запрос.препарат.срок_годности
                + ", дата продажи " + запрос.дата_продажи
            );
        }
    }
}
