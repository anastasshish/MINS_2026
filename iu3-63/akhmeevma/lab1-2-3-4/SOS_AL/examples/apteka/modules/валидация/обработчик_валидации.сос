// Chain of Responsibility — базовый обработчик валидации

подключить "../модель/запрос_продажи.сос";

класс ОбработчикВалидации() {
    публичный ОбработчикВалидации следующий;
    публичный логическое есть_следующий;

    конструктор() {
        этот.есть_следующий = нет;
    }

    публичный функция установить_следующий(ОбработчикВалидации обработчик) {
        этот.следующий = обработчик;
        этот.есть_следующий = да;
    }

    публичный функция проверить(ЗапросПродажи запрос) {
        этот.обработать(запрос);
        если (этот.есть_следующий) {
            этот.следующий.проверить(запрос);
        }
    }

    публичный функция обработать(ЗапросПродажи запрос) {
    }
}
