// Chain — проверка наличия на складе

подключить "обработчик_валидации.сос";
подключить "../общее/ошибки_аптеки.сос";

класс ПроверкаСклада(ОбработчикВалидации) {
    переопределить публичный функция обработать(ЗапросПродажи запрос) {
        если (запрос.препарат.количество < запрос.количество) {
            бросить новый ошибка_склада(
                "недостаточно на складе: есть " + строка(запрос.препарат.количество)
                + ", запрошено " + строка(запрос.количество)
            );
        }
    }
}
