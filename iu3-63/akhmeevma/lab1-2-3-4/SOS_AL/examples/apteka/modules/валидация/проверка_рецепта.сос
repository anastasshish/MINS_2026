// Chain — проверка рецепта для рецептурных препаратов

подключить "обработчик_валидации.сос";
подключить "../общее/ошибки_аптеки.сос";

класс ПроверкаРецепта(ОбработчикВалидации) {
    переопределить публичный функция обработать(ЗапросПродажи запрос) {
        если (запрос.препарат.рецептурный() и длина(запрос.номер_рецепта) == 0) {
            бросить новый ошибка_рецепта(
                "для рецептурного препарата нужен рецепт: " + запрос.препарат.название
            );
        }
    }
}
