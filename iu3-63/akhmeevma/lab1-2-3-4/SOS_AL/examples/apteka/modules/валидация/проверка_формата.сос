// Chain — проверка формата запроса

подключить "обработчик_валидации.сос";
подключить "../общее/ошибки_аптеки.сос";

класс ПроверкаФормата(ОбработчикВалидации) {
    переопределить публичный функция обработать(ЗапросПродажи запрос) {
        если (запрос.ид_препарата <= 0) {
            бросить новый ошибка_формата("неверный идентификатор препарата");
        }
        если (запрос.количество <= 0) {
            бросить новый ошибка_формата("количество должно быть положительным");
        }
    }
}
