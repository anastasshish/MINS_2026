// Strategy — поиск препаратов с истекающим сроком годности

подключить "../интерфейсы/интерфейс_стратегия_поиска.сос";

класс ПоискИстекающих() реализует ИнтерфейсСтратегияПоиска {
    публичный функция найти(Препарат[] список, строка запрос) Препарат[] {
        Препарат[] результат = новый Препарат[0];
        целое сч = 0;
        пока (сч < длина(список)) выполнять {
            если (список[сч].истекает_до(запрос)) {
                добавить(результат, список[сч]);
            }
            сч += 1;
        }
        вернуть результат;
    }
}
