// Strategy — поиск по названию

подключить "../интерфейсы/интерфейс_стратегия_поиска.сос";

класс ПоискПоНазванию() реализует ИнтерфейсСтратегияПоиска {
    публичный функция найти(Препарат[] список, строка запрос) Препарат[] {
        Препарат[] результат = новый Препарат[0];
        целое сч = 0;
        пока (сч < длина(список)) выполнять {
            строка имя = список[сч].название;
            логическое совпадение = нет;
            целое инд = 0;
            пока (инд < длина(имя)) выполнять {
                если (инд + длина(запрос) <= длина(имя)) {
                    логическое равны = да;
                    целое поз = 0;
                    пока (поз < длина(запрос)) выполнять {
                        если (имя[инд + поз] != запрос[поз]) {
                            равны = нет;
                        }
                        поз += 1;
                    }
                    если (равны) {
                        совпадение = да;
                    }
                }
                инд += 1;
            }
            если (совпадение) {
                добавить(результат, список[сч]);
            }
            сч += 1;
        }
        вернуть результат;
    }
}
