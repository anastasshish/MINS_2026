// Strategy — сортировка по сроку годности (пузырьковая)

подключить "../интерфейсы/интерфейс_стратегия_сортировки.сос";

класс СортировкаПоСроку() реализует ИнтерфейсСтратегияСортировки {
    публичный функция отсортировать(Препарат[] список) Препарат[] {
        Препарат[] копия = новый Препарат[0];
        целое сч = 0;
        пока (сч < длина(список)) выполнять {
            добавить(копия, список[сч]);
            сч += 1;
        }
        целое размер = длина(копия);
        целое внеш = 0;
        пока (внеш < размер - 1) выполнять {
            целое внутр = 0;
            пока (внутр < размер - внеш - 1) выполнять {
                если (копия[внутр].срок_годности > копия[внутр + 1].срок_годности) {
                    Препарат буфер = копия[внутр];
                    копия[внутр] = копия[внутр + 1];
                    копия[внутр + 1] = буфер;
                }
                внутр += 1;
            }
            внеш += 1;
        }
        вернуть копия;
    }
}
