// Observer — вывод уведомлений в консоль

подключить "базовый_наблюдатель.сос";
подключить "../интерфейсы/интерфейс_наблюдатель.сос";

класс НаблюдательКонсоли(БазовыйНаблюдатель) реализует ИнтерфейсНаблюдатель {
    переопределить публичный функция уведомить(строка событие, строка сообщение) {
        печать("[УВЕДОМЛЕНИЕ]", событие + ":", сообщение);
    }
}
