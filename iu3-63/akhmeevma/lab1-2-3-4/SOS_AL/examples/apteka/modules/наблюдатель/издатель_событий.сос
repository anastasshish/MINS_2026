// Observer — издатель событий (Subject)

подключить "базовый_наблюдатель.сос";

класс ИздательСобытий() {
    публичный БазовыйНаблюдатель[] наблюдатели;

    конструктор() {
        этот.наблюдатели = новый БазовыйНаблюдатель[0];
    }

    публичный функция подписать(БазовыйНаблюдатель наблюдатель) {
        добавить(этот.наблюдатели, наблюдатель);
    }

    публичный функция оповестить(строка событие, строка сообщение) {
        целое сч = 0;
        пока (сч < длина(этот.наблюдатели)) выполнять {
            этот.наблюдатели[сч].уведомить(событие, сообщение);
            сч += 1;
        }
    }
}
