// Сервис аптеки — фасад, объединяющий все подсистемы

подключить "../общее/ошибки_аптеки.сос";
подключить "../фабрика/фабрика_препаратов.сос";
подключить "../репозиторий/репозиторий_препаратов.сос";
подключить "../репозиторий/репозиторий_продаж.сос";
подключить "../стратегии/поиск_по_названию.сос";
подключить "../стратегии/поиск_истекающих.сос";
подключить "../стратегии/сортировка_по_сроку.сос";
подключить "../наблюдатель/издатель_событий.сос";
подключить "../наблюдатель/наблюдатель_консоли.сос";
подключить "../валидация/проверка_формата.сос";
подключить "../валидация/проверка_срока.сос";
подключить "../валидация/проверка_склада.сос";
подключить "../валидация/проверка_рецепта.сос";
подключить "../транзакции/единица_работы.сос";
подключить "../модель/запрос_продажи.сос";
подключить "../общее/тестовые_данные.сос";

класс СервисАптеки() {
    публичный РепозиторийПрепаратов репозиторий_препаратов;
    публичный РепозиторийПродаж репозиторий_продаж;
    публичный ФабрикаПрепаратов фабрика;
    публичный ИздательСобытий издатель;
    публичный ЕдиницаРаботы единица_работы;
    приватный ОбработчикВалидации цепочка_валидации;

    конструктор(строка путь_препараты, строка путь_продажи) {
        этот.репозиторий_препаратов = новый РепозиторийПрепаратов(путь_препараты);
        этот.репозиторий_продаж = новый РепозиторийПродаж(путь_продажи);
        этот.фабрика = новый ФабрикаПрепаратов();
        этот.издатель = новый ИздательСобытий();
        этот.издатель.подписать(новый НаблюдательКонсоли());
        этот.единица_работы = новый ЕдиницаРаботы(этот.репозиторий_препаратов, этот.репозиторий_продаж);
        этот.цепочка_валидации = этот.собрать_цепочку();
    }

    приватный функция собрать_цепочку() ОбработчикВалидации {
        ПроверкаФормата формат = новый ПроверкаФормата();
        ПроверкаСрока срок = новый ПроверкаСрока();
        ПроверкаСклада склад = новый ПроверкаСклада();
        ПроверкаРецепта рецепт = новый ПроверкаРецепта();
        формат.установить_следующий(срок);
        срок.установить_следующий(склад);
        склад.установить_следующий(рецепт);
        вернуть формат;
    }

    публичный функция загрузить_данные() {
        этот.репозиторий_препаратов.загрузить();
        этот.репозиторий_продаж.загрузить();
    }

    публичный функция сбросить_тестовые_данные() {
        ТестовыеДанные данные = новый ТестовыеДанные();
        записать_файл(этот.репозиторий_препаратов.путь, данные.текст_препаратов());
        записать_файл(этот.репозиторий_продаж.путь, данные.текст_продаж());
        этот.загрузить_данные();
        этот.издатель.оповестить("сброс", "Данные сброшены до тестовых значений по умолчанию");
    }

    публичный функция добавить_препарат(строка тип, целое ид, строка название, вещественное цена, целое количество, строка срок_годности) {
        Препарат п = этот.фабрика.создать(тип, ид, название, цена, количество, срок_годности);
        этот.репозиторий_препаратов.добавить(п);
        этот.репозиторий_препаратов.сохранить();
        этот.издатель.оповестить("поступление", "Добавлен препарат: " + п.описание());
    }

    публичный функция найти_по_названию(строка запрос) Препарат[] {
        ПоискПоНазванию стратегия = новый ПоискПоНазванию();
        вернуть стратегия.найти(этот.репозиторий_препаратов.все(), запрос);
    }

    публичный функция найти_истекающие(строка до_даты) Препарат[] {
        ПоискИстекающих стратегия = новый ПоискИстекающих();
        вернуть стратегия.найти(этот.репозиторий_препаратов.все(), до_даты);
    }

    публичный функция отсортировать_по_сроку() Препарат[] {
        СортировкаПоСроку стратегия = новый СортировкаПоСроку();
        вернуть стратегия.отсортировать(этот.репозиторий_препаратов.все());
    }

    публичный функция продать(целое ид_препарата, целое количество, строка дата, строка номер_рецепта) Продажа {
        ЗапросПродажи запрос = новый ЗапросПродажи(ид_препарата, количество, номер_рецепта);
        запрос.препарат = этот.репозиторий_препаратов.найти_по_ид(ид_препарата);
        запрос.дата_продажи = дата;
        этот.цепочка_валидации.проверить(запрос);
        Продажа продажа = этот.единица_работы.выполнить_продажу(запрос.препарат, количество, дата, номер_рецепта);
        этот.издатель.оповестить("продажа", продажа.описание());
        вернуть продажа;
    }

    публичный функция списать_препарат(целое ид) {
        Препарат п = этот.репозиторий_препаратов.найти_по_ид(ид);
        строка описание = п.описание();
        этот.репозиторий_препаратов.удалить_по_ид(ид);
        этот.репозиторий_препаратов.сохранить();
        этот.издатель.оповестить("списание", "Списан препарат: " + описание);
    }

    публичный функция журнал_продаж() Продажа[] {
        вернуть этот.репозиторий_продаж.все();
    }

    публичный функция список_препаратов() Препарат[] {
        вернуть этот.репозиторий_препаратов.все();
    }

    публичный функция следующий_ид_препарата() целое {
        вернуть этот.репозиторий_препаратов.следующий_ид();
    }

    публичный функция получить_препарат(целое ид) Препарат {
        вернуть этот.репозиторий_препаратов.найти_по_ид(ид);
    }

    публичный функция фильтр_по_рецептурности(логическое рецептурный) Препарат[] {
        Препарат[] результат = новый Препарат[0];
        Препарат[] все = этот.репозиторий_препаратов.все();
        целое сч = 0;
        пока (сч < длина(все)) выполнять {
            если (все[сч].рецептурный() == рецептурный) {
                добавить(результат, все[сч]);
            }
            сч += 1;
        }
        вернуть результат;
    }
}
