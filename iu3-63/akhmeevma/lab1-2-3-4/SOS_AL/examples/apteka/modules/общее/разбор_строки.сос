// Утилита для разбора текстовых данных (DRY)

класс РазборСтроки() {
    публичный функция разделить(строка текст, символ разделитель) строка[] {
        строка[] части = новый строка[0];
        строка текущая = "";
        целое сч = 0;
        пока (сч < длина(текст)) выполнять {
            символ сим = текст[сч];
            если (сим == разделитель) {
                добавить(части, текущая);
                текущая = "";
            } иначе {
                текущая = текущая + сим;
            }
            сч += 1;
        }
        добавить(части, текущая);
        вернуть части;
    }

    публичный функция строки_из_текста(строка текст) строка[] {
        вернуть этот.разделить(текст, '\n');
    }

    // Убирает символ \r в конце (Windows-перевод строки)
    публичный функция обрезать(строка текст) строка {
        если (длина(текст) > 0 и текст[длина(текст) - 1] == '\r') {
            строка результат = "";
            целое сч = 0;
            пока (сч < длина(текст) - 1) выполнять {
                результат = результат + текст[сч];
                сч += 1;
            }
            вернуть результат;
        }
        вернуть текст;
    }

    публичный функция не_пустая(строка строка_данных) логическое {
        вернуть длина(строка_данных) > 0;
    }
}
