// Информационная система аптеки — интерактивное консольное приложение

подключить "modules/ui/консоль_аптеки.сос";

функция начало_начал() {
    СервисАптеки аптека = новый СервисАптеки("data/препараты.txt", "data/продажи.txt");
    аптека.загрузить_данные();

    печать("Добро пожаловать в систему управления аптекой!");
    печать("Данные загружены из data/препараты.txt и data/продажи.txt");

    КонсольАптеки консоль = новый КонсольАптеки(аптека);
    консоль.запустить();
}
