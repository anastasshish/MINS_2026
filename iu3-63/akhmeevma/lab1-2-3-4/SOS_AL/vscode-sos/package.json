{
  "name": "sos-language",
  "displayName": "Язык Сос",
  "description": "Подсветка синтаксиса для языка программирования «Сос»",
  "version": "0.1.1",
  "publisher": "sos-local",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "sos",
        "aliases": [
          "Сос",
          "Sos",
          "sos"
        ],
        "extensions": [
          ".сос",
          ".сos"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sos",
        "scopeName": "source.sos",
        "path": "./syntaxes/sos.tmLanguage.json"
      }
    ]
  }
}
