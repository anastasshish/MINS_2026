{
  "$schema": "https://raw.githubusercontent.com/martinring/amln/master/schema/tmlanguage.json",
  "name": "Sos",
  "scopeName": "source.sos",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#chars" },
    { "include": "#numbers" },
    { "include": "#member-access" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#types-and-builtins" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.sos",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.sos",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.sos",
          "match": "\\\\."
        }
      ]
    },
    "chars": {
      "name": "string.quoted.single.sos",
      "match": "'(?:\\\\.|[^'\\\\])'"
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.sos",
          "match": "(?<![邪-褟袗-携褢衼0-9_])-?\\d+\\.\\d+(?![0-9])"
        },
        {
          "name": "constant.numeric.integer.sos",
          "match": "(?<![邪-褟袗-携褢衼0-9_])-?\\d+(?![0-9])"
        }
      ]
    },
    "member-access": {
      "patterns": [
        {
          "name": "variable.other.member.sos",
          "match": "(?:褝褌芯褌|褉芯写懈褌械谢褜|[袗-携衼][邪-褟袗-携褢衼0-9?!_-]*|[邪-褟褢][邪-褟袗-携褢衼0-9?!_-]*)(?:\\.[邪-褟褢袗-携衼][邪-褟袗-携褢衼0-9?!_-]*)+"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.declaration.sos",
          "match": "(?:^|(?<=[^邪-褟袗-携褢衼0-9_?!\\-]))(?:薪邪褔邪谢芯_薪邪褔邪谢|泻芯薪褋褌褉褍泻褌芯褉|懈薪褌械褉褎械泄褋|褉械邪谢懈蟹褍械褌|锌芯写泻谢褞褔懈褌褜|褎褍薪泻褑懈褟|薪芯胁褘泄|泻谢邪褋褋)(?:(?=[^邪-褟袗-携褢衼0-9_?!\\-])|$)"
        },
        {
          "name": "storage.modifier.sos",
          "match": "(?:^|(?<=[^邪-褟袗-携褢衼0-9_?!\\-]))(?:锌械褉械芯锌褉械写械谢懈褌褜|蟹邪褖懈褖褢薪薪褘泄|锌褍斜谢懈褔薪褘泄|锌褉懈胁邪褌薪褘泄)(?:(?=[^邪-褟袗-携褢衼0-9_?!\\-])|$)"
        },
        {
          "name": "keyword.control.exception.sos",
          "match": "(?:^|(?<=[^邪-褟袗-携褢衼0-9_?!\\-]))(?:锌芯锌褉芯斜芯胁邪褌褜|褋谢芯胁懈褌褜|薪邪泻芯薪械褑|斜褉芯褋懈褌褜)(?:(?=[^邪-褟袗-携褢衼0-9_?!\\-])|$)"
        },
        {
          "name": "keyword.control.sos",
          "match": "(?:^|(?<=[^邪-褟袗-携褢衼0-9_?!\\-]))(?:懈薪邪褔械_械褋谢懈|胁褘锌芯谢薪褟褌褜|锌褉芯写芯谢卸懈褌褜|锌褉械褉胁邪褌褜|胁邪褉懈邪薪褌|胁褘斜褉邪褌褜|胁械褉薪褍褌褜|写械谢邪褌褜|胁褘泄褌懈|懈薪邪褔械|锌芯泻邪|械褋谢懈|写谢褟|泻邪泻)(?:(?=[^邪-褟袗-携褢衼0-9_?!\\-])|$)"
        },
        {
          "name": "keyword.operator.word.sos",
          "match": "(?:^|(?<=[^邪-褟袗-携褢衼0-9_?!\\-]))(?:懈谢懈)(?:(?=[^邪-褟袗-携褢衼0-9_?!\\-])|$)"
        },
        {
          "name": "keyword.operator.word.sos",
          "match": "(?:^|(?<=[^邪-褟袗-携褢衼0-9_?!\\-]))(?:懈|薪械|胁)(?:(?=[^邪-褟袗-携褢衼0-9_?!\\-])|$)"
        },
        {
          "name": "variable.language.sos",
          "match": "(?:^|(?<=[^邪-褟袗-携褢衼0-9_?!\\-]))(?:褝褌芯褌|褉芯写懈褌械谢褜)(?:(?=[^邪-褟袗-携褢衼0-9_?!\\-])|$)"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.sos",
          "match": "(?:^|(?<=[^邪-褟袗-携褢衼0-9_?!\\-]))(?:写邪|薪械褌)(?:(?=[^邪-褟袗-携褢衼0-9_?!\\-])|$)"
        },
        {
          "name": "constant.language.null.sos",
          "match": "(?:^|(?<=[^邪-褟袗-携褢衼0-9_?!\\-]))袧褍谢褜(?:(?=[^邪-褟袗-携褢衼0-9_?!\\-])|$)"
        }
      ]
    },
    "types-and-builtins": {
      "patterns": [
        {
          "name": "support.function.sos",
          "match": "(?:^|(?<=[^邪-褟袗-携褢衼0-9_?!\\-]))(?:写芯斜邪胁懈褌褜_胁_褎邪泄谢|锌褉芯褔懈褌邪褌褜_褎邪泄谢|蟹邪锌懈褋邪褌褜_褎邪泄谢|褝褌芯_褝泻蟹械屑锌谢褟褉|写芯斜邪胁懈褌褜|锌械褔邪褌褜|胁胁芯写|写谢懈薪邪)(?:(?=[^邪-褟袗-携褢衼0-9_?!\\-])|$)"
        },
        {
          "name": "storage.type.sos",
          "match": "(?:^|(?<=[^邪-褟袗-携褢衼0-9_?!\\-]))(?:胁械褖械褋褌胁械薪薪芯械|谢芯谐懈褔械褋泻芯械|褋谢芯胁邪褉褜|褋懈屑胁芯谢|褋褌褉芯泻邪|褑械谢芯械|锌褍褋褌芯械|褌懈锌)(?:(?=[^邪-褟袗-携褢衼0-9_?!\\-])|$)"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.sos",
          "match": "\\+\\+=|--=|\\+=|-="
        },
        {
          "name": "keyword.operator.comparison.sos",
          "match": "==|!=|<=|>="
        },
        {
          "name": "keyword.operator.arithmetic.sos",
          "match": "[+*/%^=<>]|(?<![0-9邪-褟袗-携褢衼_])-(?![0-9])"
        },
        {
          "name": "punctuation.terminator.sos",
          "match": ";"
        },
        {
          "name": "punctuation.separator.sos",
          "match": ","
        },
        {
          "name": "punctuation.bracket.sos",
          "match": "[{}\\[\\]():]"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.type.class.sos",
          "match": "[袗-携衼][邪-褟袗-携褢衼0-9?!_-]*"
        },
        {
          "name": "variable.other.sos",
          "match": "[邪-褟褢][邪-褟袗-携褢衼0-9?!_-]*|[邪-褟袗-携褢衼0-9?!_-]+"
        }
      ]
    }
  }
}
